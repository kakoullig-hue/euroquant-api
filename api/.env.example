# ════════════════════════════════════════════════════════════
# EuroQuant API — Environment Configuration
# Copy to .env and fill in your values
# ════════════════════════════════════════════════════════════

# ── API Authentication ──────────────────────────────────────
# Comma-separated list of valid API keys (use long random strings in prod)
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(32))"
EUROQUANT_API_KEYS=replace_with_generated_key_1,replace_with_generated_key_2

# ── CORS — Allowed dashboard origins ────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.euroquant.io

# ── File handling ───────────────────────────────────────────
MAX_INGESTION_MB=50

# ── Anthropic API (Jarvis backbone) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Neo4j (Mission 2 + Benchmarking) ────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── OpenCorporates (Mission 3 — company verification) ───────
OPENCORPORATES_API_KEY=

# ── Sanctions cache (FIX-5) ─────────────────────────────────
# Default 24h. Set lower for high-risk workflows.
SANCTIONS_CACHE_TTL_HOURS=24

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
