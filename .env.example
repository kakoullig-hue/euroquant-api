# EuroQuant Risk Terminal — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.

# ── Anthropic / Jarvis engine ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
JARVIS_MODEL=claude-sonnet-4-6

# ── FastAPI gateway auth ───────────────────────────────────────────
# Store bcrypt-hashed keys, not plaintext. Generate with:
#   python scripts/hash_key.py <your-key>
EUROQUANT_API_KEYS=<bcrypt-hash-1>,<bcrypt-hash-2>

# ── Neo4j graph database ──────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=yourpassword

# ── Redis (multi-worker circuit breaker + PEP refresh timestamp) ──
REDIS_URL=redis://localhost:6379/0

# ── Sanctions cache ───────────────────────────────────────────────
SANCTIONS_CACHE_TTL_HOURS=24   # set to 1 for high-risk workflows

# ── OpenCorporates company verification ───────────────────────────
OPENCORPORATES_API_KEY=
OPENCORP_RATE_LIMIT=10:5       # rate:burst (requests/second)

# ── M-1.1: EU PEP registry feed (refreshed every 24h by APScheduler)
# Default: EU Consolidated Sanctions XML feed.
# Override with a dedicated PEP vendor feed (Refinitiv, Dow Jones, etc.)
PEP_FEED_URL=https://webgate.ec.europa.eu/fsd/fsf/public/files/xmlFullSanctionsList_1_1/content

# ── File ingestion ────────────────────────────────────────────────
MAX_INGESTION_MB=50

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
