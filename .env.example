# ══════════════════════════════════════════════════════════════════════
# EuroQuant Risk Terminal — Environment Variables
# Copy to api/.env and fill in your values.
# NEVER commit api/.env or any file containing real secrets.
# ══════════════════════════════════════════════════════════════════════

# ── Anthropic API (Jarvis backbone) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── EuroQuant API Keys (bcrypt-hashed — M-0.3) ─────────────────────────
# Keys are stored as bcrypt hashes. Never store plaintext here.
#
# To add a new key:
#   1. Generate a random key:   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   2. Hash it:                 python scripts/hash_key.py <your-key>
#   3. Paste the hash below (comma-separate multiple hashes, no spaces)
#
EUROQUANT_API_KEYS=$2b$12$examplehashhere...,

# ── Redis — shared circuit-breaker state (M-0.2) ───────────────────────
# Required when running uvicorn with --workers > 1 so all workers share
# the circuit breaker state. Leave unset for single-worker / dev.
REDIS_URL=redis://localhost:6379

# ── Neo4j ──────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=yourpassword

# ── OpenCorporates ─────────────────────────────────────────────────────
OPENCORPORATES_API_KEY=

# Token-bucket rate limit for OpenCorporates calls (M-1.2)
# Format: rate:burst  (requests/second : max-burst)
# Default 10:5 — increase with a paid API key (500 req/min allowed)
OPENCORP_RATE_LIMIT=10:5

# ── Jarvis Engine ──────────────────────────────────────────────────────
JARVIS_MODEL=claude-sonnet-4-6
MAX_INGESTION_MB=50

# Sanctions cache TTL — lower for high-risk workflows
SANCTIONS_CACHE_TTL_HOURS=24

# ── FastAPI ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
